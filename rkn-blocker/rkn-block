#!/bin/bash
#
# RKN Blocker Management CLI
# Консольная утилита для управления блокировщиком
#
# Usage:
#   rkn-block [enable|disable|status|update|toggle|logs]
#

set -e

# Цвета
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Пути
INSTALL_DIR="/opt/rkn-blocker"
ENV_FILE="/etc/rkn-blocker.env"
BLOCK_SCRIPT="$INSTALL_DIR/block_ips.py"
VENV_PYTHON="$INSTALL_DIR/venv/bin/python3"

# Загрузка токена
load_token() {
    if [[ -f "$ENV_FILE" ]]; then
        grep "^RKN_API_TOKEN=" "$ENV_FILE" | cut -d'=' -f2 | tr -d '[:space:]'
    else
        echo ""
    fi
}

# API вызов
api_call() {
    local method=$1
    local endpoint=$2
    local token=$(load_token)
    
    if [[ -z "$token" ]]; then
        echo -e "${RED}Ошибка: API токен не найден в $ENV_FILE${NC}"
        exit 1
    fi
    
    local response
    if [[ "$method" == "GET" ]]; then
        response=$(curl -s -w "\n%{http_code}" \
            -H "X-RKN-Token: $token" \
            "http://127.0.0.1:8765$endpoint")
    else
        response=$(curl -s -w "\n%{http_code}" \
            -X POST \
            -H "X-RKN-Token: $token" \
            -H "Content-Type: application/json" \
            -d "{\"token\":\"$token\"}" \
            "http://127.0.0.1:8765$endpoint")
    fi
    
    local body=$(echo "$response" | head -n -1)
    local code=$(echo "$response" | tail -n 1)
    
    if [[ "$code" == "401" ]]; then
        echo -e "${RED}Ошибка авторизации. Проверьте API токен.${NC}"
        exit 1
    elif [[ "$code" != "200" ]]; then
        echo -e "${RED}Ошибка API: HTTP $code${NC}"
        echo "$body"
        exit 1
    fi
    
    echo "$body"
}

# Форматирование JSON вывода
format_json() {
    python3 -c "
import json
import sys
try:
    data = json.load(sys.stdin)
    for key, value in data.items():
        if value is True:
            value = '✅ Да'
        elif value is False:
            value = '❌ Нет'
        elif value is None:
            value = '—'
        print(f'{key}: {value}')
except:
    pass
"
}

# Показать статус
show_status() {
    echo -e "${BLUE}=== Статус RKN блокировщика ===${NC}"
    echo ""
    
    # Проверка API
    if ! systemctl is-active --quiet rkn-api.service; then
        echo -e "${RED}API сервер не запущен${NC}"
        echo "Запустите: sudo systemctl start rkn-api.service"
        exit 1
    fi
    
    local status=$(api_call GET "/status")
    
    echo "$status" | format_json
    echo ""
    
    # Дополнительная информация
    echo -e "${BLUE}Сервисы:${NC}"
    if systemctl is-active --quiet rkn-api.service; then
        echo -e "  API сервер: ${GREEN}● активен${NC}"
    else
        echo -e "  API сервер: ${RED}○ не активен${NC}"
    fi
    
    if systemctl is-active --quiet rkn-blocker.timer; then
        echo -e "  Таймер: ${GREEN}● активен${NC}"
    else
        echo -e "  Таймер: ${YELLOW}○ не активен${NC}"
    fi
    
    echo ""
}

# Включить блокировку
enable_blocking() {
    echo -e "${BLUE}Включение блокировки...${NC}"
    local result=$(api_call POST "/enable")
    echo "$result" | format_json
    
    if echo "$result" | grep -q '"success": true'; then
        echo -e "${GREEN}✅ Блокировка включена${NC}"
    else
        echo -e "${RED}❌ Ошибка включения${NC}"
    fi
}

# Выключить блокировку
disable_blocking() {
    echo -e "${BLUE}Выключение блокировки...${NC}"
    local result=$(api_call POST "/disable")
    
    if echo "$result" | grep -q '"success": true'; then
        echo -e "${GREEN}✅ Блокировка выключена${NC}"
    else
        echo -e "${RED}❌ Ошибка выключения${NC}"
    fi
}

# Переключить состояние
toggle_blocking() {
    echo -e "${BLUE}Переключение состояния...${NC}"
    local result=$(api_call POST "/toggle")
    echo "$result" | format_json
}

# Обновить списки
update_lists() {
    echo -e "${BLUE}Обновление списков блокировки...${NC}"
    local result=$(api_call POST "/update")
    echo "$result" | format_json
    
    if echo "$result" | grep -q '"success": true'; then
        echo -e "${GREEN}✅ Списки обновлены${NC}"
    else
        echo -e "${RED}❌ Ошибка обновления${NC}"
    fi
}

# Показать логи
show_logs() {
    echo -e "${BLUE}Логи RKN блокировщика (Ctrl+C для выхода)${NC}"
    echo ""
    journalctl -u rkn-blocker.service -u rkn-api.service -f --no-pager
}

# Показать помощь
show_help() {
    echo ""
    echo -e "${BLUE}RKN Blocker CLI${NC}"
    echo "Управление блокировщиком запрещённых ресурсов"
    echo ""
    echo -e "${YELLOW}Использование:${NC}"
    echo "  rkn-block <команда>"
    echo ""
    echo -e "${YELLOW}Команды:${NC}"
    echo "  status   - Показать статус блокировщика"
    echo "  enable   - Включить блокировку"
    echo "  disable  - Выключить блокировку"
    echo "  toggle   - Переключить состояние"
    echo "  update   - Обновить списки блокировки"
    echo "  logs     - Показать логи в реальном времени"
    echo "  help     - Показать эту справку"
    echo ""
    echo -e "${YELLOW}Примеры:${NC}"
    echo "  rkn-block status"
    echo "  rkn-block enable"
    echo "  rkn-block logs"
    echo ""
}

# Главная функция
main() {
    case "${1:-help}" in
        status|st)
            show_status
            ;;
        enable|on|start)
            enable_blocking
            ;;
        disable|off|stop)
            disable_blocking
            ;;
        toggle|switch)
            toggle_blocking
            ;;
        update|up|refresh)
            update_lists
            ;;
        logs|log|f)
            show_logs
            ;;
        help|h|*)
            show_help
            ;;
    esac
}

main "$@"
